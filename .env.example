APP_NAME=Asset Tracker
APP_ENV=development
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Use this for PostgreSQL in production/staging (Neon recommended)
DATABASE_URL=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=asset_tracker

# SQLite fallback for development
SQLITE_DB_PATH=./asset_tracker.db

CORS_ORIGINS=*

DEFAULT_ADMIN_NAME=IT Admin
DEFAULT_ADMIN_EMAIL=admin@company.com
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_VIEWER_EMAILS=ceo@company.com,hr@company.com,accounts@company.com
DEFAULT_VIEWER_PASSWORD=Viewer@123
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
